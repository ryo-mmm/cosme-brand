APP_NAME="LUMIÈRE BOTANIQUE"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ja
APP_FALLBACK_LOCALE=ja
APP_FAKER_LOCALE=ja_JP
APP_TIMEZONE=Asia/Tokyo

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database ---
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=cosme_brand
# DB_USERNAME=root
# DB_PASSWORD=

# --- Session ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Queue (Redis 推奨: QUEUE_CONNECTION=redis) ---
QUEUE_CONNECTION=redis

# --- Cache ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
CACHE_STORE=redis

# --- Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (本番: smtp / 開発: Mailpit port 1025) ---
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@lumiere-botanique.jp"
MAIL_FROM_NAME="${APP_NAME}"

# --- Stripe ---
STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price ID（定期便コース）
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_BIMONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxxxx

# 定期便の表示価格（Stripe Price とは別に表示用として管理）
SUBSCRIPTION_PRICE_MONTHLY=5800
SUBSCRIPTION_PRICE_BIMONTHLY=5800

# --- Cashier ---
CASHIER_CURRENCY=jpy
CASHIER_CURRENCY_LOCALE=ja

# --- Admin ---
ADMIN_EMAIL=admin@lumiere-botanique.jp

# --- AWS（画像ストレージなどで利用する場合） ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_STRIPE_KEY="${STRIPE_KEY}"
